`timescale 1ns/1ps

module alu_4bit(
  input logic [3:0]a,
  input logic [3:0]b,
  input logic [2:0]op,
  output logic [3:0]result,
  output logic carry
);
  always_comb begin
    carry = 0;
    case(op)
      3'b000:{carry, result} = a + b;
      3'b001:{carry, result} = a - b;
      3'b010:result = a&b;
      3'b011:result = a|b;
      3'b100:result = a^b;
      3'b101:result = ~a;
      3'b110:result = a<<1;
      3'b111:result = a>>1;
      default:result = 0;
    endcase
  end
endmodule
