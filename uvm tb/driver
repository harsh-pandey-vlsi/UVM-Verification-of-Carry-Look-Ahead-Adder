//DRIVER
class cla_driver extends uvm_driver #(cla_txn);
  `uvm_component_utils(cla_driver)
  
  virtual cla_if vif;
  
  function new(string name, uvm_component parent);
    super.new(name,parent);
  endfunction
  
  function void build_phase(uvm_phase phase);
    if(!uvm_config_db#(virtual cla_if)::get(this, "", "vif", vif))
      `uvm_fatal("DRV", "No interface")
  endfunction
      
  task run_phase(uvm_phase phase);
    cla_txn txn;
    forever begin
      seq_item_port.get_next_item(txn);
      vif.a=txn.a;
      vif.b=txn.b;
      vif.cin=txn.cin;
      #1;
      seq_item_port.item_done();
    end
  endtask
endclass
    
