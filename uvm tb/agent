class cla_agent extends uvm_agent;
  `uvm_component_utils(cla_agent)
  cla_driver drv;
  cla_monitor mon;
  uvm_sequencer #(cla_txn) seqr;
  
  function new(string name, uvm_component parent);
    super.new(name, parent);
  endfunction
  
  function void build_phase(uvm_phase phase);
    drv = cla_driver::type_id::create("drv",this);
    mon = cla_monitor::type_id::create("mon",this);
    seqr = uvm_sequencer#(cla_txn)::type_id::create("seqr",this);
  endfunction
  
  function void connect_phase(uvm_phase phase);
    drv.seq_item_port.connect(seqr.seq_item_export);
  endfunction
endclass
